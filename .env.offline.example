# ── Offline-modus (laptop-bruk ved nettverksoutage) ──────────────────────
# Kopier til .env før du starter offline-serveren.
#
# VIKTIG: Denne filen skal brukes KUN på event-laptopen. Aldri på Railway.

SECRET_KEY=offline-event-nokkel-bytt-meg-ved-hvert-event
DEBUG=False

# Offline-modus: skrur av HTTPS-tvang og HSTS slik at serveren fungerer
# over rent HTTP. DEBUG holdes False for sikker drift.
OFFLINE_MODE=True

ALLOWED_HOSTS=*
DATABASE_URL=sqlite:///offline.sqlite3
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Slå av rate-limit for offline-bruk (alle er bak samme lokal-IP)
RATELIMIT_ENABLE=False
